{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "types": ["@cloudflare/workers-types"],
    "noEmit": true
  },
  "include": [
    "src"
    // "worker-configuration.d.ts" — generated by `wrangler types`, uncomment after running it.
    // Run: pnpm --filter @nqdrive/worker cf-typegen
  ],
  // File khusus runtime Node (VPS standalone) — di-typecheck terpisah lewat
  // tsconfig.node.json (pnpm typecheck:node) karena butuh types "node".
  "exclude": ["src/node-entry.ts", "src/adapters"]
}
