# ============================================================================
# NQDRIVE — konfigurasi standalone Node/VPS (BUKAN untuk Cloudflare).
# Copy file ini ke ".env" (gitignored) di apps/worker, isi nilai aslinya.
# Deployment Cloudflare tetap pakai wrangler.jsonc + `wrangler secret put`.
# ============================================================================

# Path file database SQLite. Buat dulu dari skema konsolidasi:
#   sqlite3 ./data/nqdrive.db < dbcloud.sql
DB_PATH=./data/nqdrive.db

# Port HTTP server Node (nginx melakukan proxy_pass ke port ini)
PORT=8787

# "production" menyembunyikan detail error dari response; "development" menampilkannya
APP_ENV=production

# URL publik tempat Google me-redirect setelah OAuth (domain VPS kamu).
# Harus terdaftar juga di Google Cloud Console -> Credentials -> Authorized redirect URIs
GOOGLE_OAUTH_REDIRECT_URI=https://drive.example.com

# URL publik web app (dipakai untuk redirect setelah login/OAuth)
WEB_APP_URL=https://drive.example.com

# Untuk sign/verify JWT session token. Generate: openssl rand -base64 48
JWT_SECRET=

# Google OAuth 2.0 (Google Cloud Console -> APIs & Services -> Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Kunci 32-byte (base64) untuk enkripsi refresh token Google Drive di database.
# Generate: openssl rand -base64 32
ENCRYPTION_KEY=
