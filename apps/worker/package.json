{
  "name": "@nqdrive/worker",
  "version": "0.1.0",
  "private": true,
  "description": "NQDRIVE Cloudflare Worker — REST API, authentication, storage orchestration, and streaming download/upload endpoints.",
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsc --noEmit",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:migrate:local": "node scripts/migrate-d1.mjs --local",
    "db:migrate:remote": "node scripts/migrate-d1.mjs --remote",
    "cf-typegen": "wrangler types",
    "start:node": "tsx src/node-entry.ts",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json"
  },
  "dependencies": {
    "@nqdrive/types": "workspace:*",
    "@nqdrive/shared": "workspace:*",
    "@nqdrive/api": "workspace:*",
    "@nqdrive/storage": "workspace:*",
    "hono": "^4.6.9",
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.4.1",
    "better-sqlite3": "^12.4.1",
    "node-cron": "^3.0.3",
    "uuid": "^10.0.0",
    "@types/uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "wrangler": "^3.84.0",
    "@cloudflare/workers-types": "^4.20241106.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.2"
  }
}
