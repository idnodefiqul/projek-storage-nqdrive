{
  "name": "nqdrive",
  "version": "0.1.0",
  "private": true,
  "description": "NQDRIVE - Virtual cloud storage that unifies multiple Google Drive accounts into a single storage pool, powered by Cloudflare Workers.",
  "author": "K",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev:web": "pnpm --filter @nqdrive/web dev",
    "dev:worker": "pnpm --filter @nqdrive/worker dev",

    "build": "pnpm --filter \"./packages/**\" build && pnpm --filter \"./apps/**\" build",
    "build:web": "pnpm --filter @nqdrive/web build",
    "build:worker": "pnpm --filter @nqdrive/worker build",

    "deploy:worker": "pnpm --filter @nqdrive/worker run deploy",
    "deploy:web": "pnpm --filter @nqdrive/web run deploy",
    "deploy:web:full": "pnpm build:web && pnpm deploy:web",

    "db:migrate:local": "pnpm --filter @nqdrive/worker db:migrate:local",
    "db:migrate:remote": "pnpm --filter @nqdrive/worker db:migrate:remote",

    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r exec rm -rf dist node_modules .wrangler && rm -rf node_modules"
  }
}
